# ========================================
# Hibiscus v0.9 Environment Configuration
# ========================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains real secrets.
# Rotate all keys regularly (every 90 days recommended).

# ========================================
# LLM PROVIDERS
# ========================================

# DeepSeek (Primary — Tier 1 & 2)
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Anthropic (Safety net — Tier 3)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI (Optional — legacy)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_MODEL=gpt-3.5-turbo

# GLM AI (Embeddings)
GLM_API_KEY=your-glm-api-key-here
GLM_BASE_URL=https://api.z.ai/api/paas/v4/
GLM_MODEL=glm-4.5

# ========================================
# APPLICATION SETTINGS
# ========================================

HIBISCUS_ENV=development
HIBISCUS_PORT=8001
HIBISCUS_LOG_LEVEL=INFO
HIBISCUS_SECRET_KEY=change-me-to-a-random-string

# ========================================
# JWT & AUTHENTICATION
# ========================================

JWT_SECRET=change-me-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION=1w

# ========================================
# DATABASE CONFIGURATION
# ========================================

# PostgreSQL — User Profiles, Portfolios, Outcomes
POSTGRES_USER=hibiscus
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=insurance_india
POSTGRESQL_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# MongoDB — Document Memory, Extractions
MONGODB_URL=mongodb://localhost:27017/
MONGODB_DB=hibiscus_db

# Redis — Session Memory, Response Cache
REDIS_URL=redis://localhost:6379/1

# Neo4j — Knowledge Graph
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-strong-neo4j-password

# Qdrant — RAG + Vector Memory
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ========================================
# CORS & SECURITY
# ========================================

# Comma-separated list of allowed CORS origins
# In production, set this to your actual frontend domains
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8001

# ========================================
# OBSERVABILITY
# ========================================

LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=hibiscus

# ========================================
# WEB SEARCH (Researcher agent)
# ========================================

TAVILY_API_KEY=your-tavily-api-key-here

# ========================================
# DOCKER COMPOSE SERVICE PASSWORDS
# ========================================
# These are used by docker-compose.yml for service containers.
# Override them here; docker-compose.yml uses ${VAR:-default} syntax.

# HIBISCUS_POSTGRES_PASSWORD=change-me-strong-db-password
# HIBISCUS_NEO4J_PASSWORD=change-me-strong-neo4j-password
# HIBISCUS_REDIS_PASSWORD=

# ========================================
# INSURER API INTEGRATIONS (Optional)
# ========================================

INSURER_API_ENABLED=false
INSURER_API_TIMEOUT=10

# ========================================
# FILE UPLOAD LIMITS
# ========================================

MAX_FILE_SIZE_MB=10
