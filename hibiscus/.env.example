# ─────────────────────────────────────────────────────────────────
# HIBISCUS v5.0 — Environment Variables
# Copy this to .env and fill in values
# ─────────────────────────────────────────────────────────────────

# ── LLM Providers ──────────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here   # Used for embeddings only

# ── Existing EAZR API ───────────────────────────────────────────
EAZR_API_BASE=http://eazr-app:8000   # Internal Docker hostname

# ── Redis (Session Memory) ──────────────────────────────────────
REDIS_URL=redis://eazr-redis:6379/1  # DB 1 for Hibiscus (DB 0 = botproject)

# ── MongoDB (Document Memory) ───────────────────────────────────
MONGODB_URL=mongodb://eazr-mongo:27017/
MONGODB_DB=hibiscus_db

# ── PostgreSQL (User Profiles, Outcomes) ────────────────────────
POSTGRESQL_URL=postgresql+asyncpg://eazr:eazr_secure_2024@eazr-postgres:5432/insurance_india

# ── Neo4j (Knowledge Graph) ─────────────────────────────────────
NEO4J_URI=bolt://hibiscus-neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=hibiscus_neo4j_2024

# ── Qdrant (RAG + Vector Memory) ────────────────────────────────
QDRANT_HOST=hibiscus-qdrant
QDRANT_PORT=6333

# ── Hibiscus Service ────────────────────────────────────────────
HIBISCUS_PORT=8001
HIBISCUS_ENV=development
HIBISCUS_LOG_LEVEL=INFO
HIBISCUS_SECRET_KEY=change_this_in_production

# ── Observability ────────────────────────────────────────────────
LANGSMITH_API_KEY=your_langsmith_key
LANGSMITH_PROJECT=hibiscus

# ── Web Search ──────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_key

# ── LLM Config ──────────────────────────────────────────────────
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=30
